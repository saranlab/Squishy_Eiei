# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (same for both client and server)
SUPABASE_URL=https://xxxx.supabase.co
# Service role key — server-side only, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Supabase (browser / Vite public) ─────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── PostHog analytics (optional — omit to disable tracking in dev) ────────────
VITE_POSTHOG_KEY=phc_...

# ── API base URL (leave empty for same-origin Vercel deployment) ──────────────
VITE_API_BASE=

# ── Phase 2: Upstash Redis (required only when using RedisStatsService) ───────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
